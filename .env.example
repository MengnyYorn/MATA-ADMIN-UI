# =============================================================================
# MATA-ADMIN-UI — copy to ".env.local" for local development (Next.js loads it).
# Never commit ".env.local" with real secrets.
# =============================================================================

# Backend API (server-side auth + next.config rewrites)
MATA_API_URL=http://localhost:8087

# Optional: browser direct calls to API (CORS must allow this origin); if unset, use same-origin /api/backend/*
# NEXT_PUBLIC_API_URL=http://localhost:8087

# NextAuth — URL of this app (change in production)
NEXTAUTH_URL=http://localhost:3000

# NextAuth — signing key for cookies (required in production; min ~32 chars)
# openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
